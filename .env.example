# Hardhat fork source when running `yarn chain` / `yarn dev:with-chain` (archive-capable HTTPS RPC).
# Alias: RPC_URL_MAINNET (same value; supported for older configs).
FORK_URL=
# RPC_URL_MAINNET=

# Local node JSON-RPC for the Next app (default http://127.0.0.1:8545).
RPC_URL=

# Seconds per block when converting "advance by days" to a block count (default 12).
BLOCK_TIME_SECONDS=

# RPC URL for the browser wallet / wagmi (default http://127.0.0.1:8545). Hardhat is set to chain id 1 (mainnet).
NEXT_PUBLIC_WALLET_RPC_URL=
